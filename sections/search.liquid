{% comment %}
  This section is used in the search template to render search results for
  products, articles, and pages.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/search
{% endcomment %}

<section class="search-page">
  <div class="search-page__inner">
    <div class="search-page__topbar">
      <a href="{{ routes.root_url }}" class="search-page__back" aria-label="Back">
        <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 24 24" role="img" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="19" y1="12" x2="5" y2="12" />
          <polyline points="12 19 5 12 12 5" />
        </svg>
      </a>

      <form action="{{ routes.search_url }}" method="get" role="search" class="search-page__topbar-form">
        <input
          class="search-page__topbar-field"
          type="search"
          size="50"
          name="q"
          value="{{ search.terms | escape }}"
          placeholder="{{ 'search.placeholder' | t }}"
        >
      </form>
    </div>

    {% assign has_results = false %}
    {% if search.performed and search.results_count > 0 %}
      {% assign has_results = true %}
    {% endif %}

    {% unless has_results %}
      <div class="search-page__header">
        <p class="search-page__eyebrow">Recent Search</p>
        <h1 class="search-page__title">{{ 'search.title' | t }}</h1>
        <p class="search-page__intro">Use the top search bar to find products quickly in a cleaner storefront flow.</p>
      </div>
    {% endunless %}

    {% if search.performed %}
      {% if search.results_count == 0 %}
        <p class="search-page__status search-page__status--empty">{{ 'search.no_results_html' | t: terms: search.terms }}</p>
      {% else %}
        <div class="search-page__results-head">
          <h1 class="search-page__query-title">{{ search.terms | escape }}</h1>
          <p class="search-page__status search-page__status--results">{{ search.results_count }} items found</p>
        </div>

        <div class="search-results">
          {% paginate search.results by 20 %}
            {% # Search result items may be an article, a page, or a product. %}
            {% for result in search.results %}
              <article class="search-result search-result--{{ result.object_type }}">
                <div class="search-result__media">
                  {% assign featured_image = result.featured_image | default: result.image %}
                  {% if featured_image %}
                    {% render 'image', class: 'search-result__image', image: featured_image, url: result.url, width: 720, height: 720, crop: 'center' %}
                  {% else %}
                    <a href="{{ result.url }}" class="search-result__image-placeholder">{{ result.title }}</a>
                  {% endif %}

                  {% if result.object_type == 'product' %}
                    {% render 'wishlist-button',
                      product_id: result.id,
                      handle: result.handle,
                      title: result.title,
                      url: result.url,
                      image: result.featured_image,
                      price: result.price,
                      class: 'wishlist-floating-button'
                    %}
                  {% endif %}
                </div>

                <div class="search-result__content">
                  <p class="search-result__type">{{ result.object_type | capitalize }}</p>
                  <h2 class="search-result__title">{{ result.title | link_to: result.url }}</h2>

                  {% if result.price %}
                    <p class="search-result__price">${{ result.price | money_without_currency }}</p>
                  {% endif %}

                  {% if result.object_type != 'product' and result.content != blank %}
                    <p class="search-result__excerpt">{{ result.content | strip_html | truncatewords: 16 }}</p>
                  {% endif %}
                </div>
              </article>
            {% endfor %}

            {{ paginate | default_pagination }}
          {% endpaginate %}
        </div>
      {% endif %}
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .search-page {
    padding: 18px 0 48px;
    background: #fff;
  }

  .search-page__inner {
    max-width: 1180px;
    margin: 0 auto;
  }

  .search-page__topbar {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    align-items: center;
    gap: 12px;
    padding: 0 16px 18px;
    border-bottom: 1px solid #ece7dd;
  }

  .search-page__back {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    color: #1f1f1f;
    text-decoration: none;
  }

  .search-page__topbar-form {
    min-width: 0;
    margin: 0;
  }

  .search-page__topbar-field {
    width: 100%;
    min-height: 54px;
    padding: 0 22px;
    border: none;
    border-radius: 999px;
    background: #f1f1f1;
    color: #161616;
    font: inherit;
    font-size: 1.02rem;
  }

  .search-page__topbar-field::placeholder {
    color: #8d8d8d;
  }

  .search-page__topbar-field:focus {
    outline: none;
    box-shadow: 0 0 0 1px #d8d8d8 inset;
  }

  .search-page__header {
    max-width: 720px;
    margin: 26px auto 0;
    padding: 0 16px;
  }

  .search-page__eyebrow {
    margin: 0 0 10px;
    color: #7a726b;
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .search-page__title {
    margin: 0;
    color: #1a1a1a;
    font-size: clamp(2rem, 5vw, 3.4rem);
    line-height: 1;
    letter-spacing: -0.06em;
  }

  .search-page__intro {
    max-width: 48ch;
    margin: 14px 0 0;
    color: #67615c;
    font-size: 1rem;
    line-height: 1.7;
  }

  .search-page__results-head {
    padding: 18px 16px 4px;
    text-align: center;
  }

  .search-page__query-title {
    margin: 0;
    color: #2a2a2a;
    font-size: clamp(1.8rem, 4vw, 3rem);
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .search-page__status {
    margin: 0;
    color: #8a837a;
    font-size: 0.96rem;
    line-height: 1.5;
  }

  .search-page__status--results {
    margin-top: 14px;
  }

  .search-page__status--empty {
    margin: 22px 16px 0;
    padding: 24px;
    border: 1px solid #ece4d9;
    border-radius: 18px;
    background: #fffaf4;
  }

  .search-results {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 20px;
    padding: 18px 16px 0;
  }

  .search-result {
    border: 1px solid #ebe3d8;
    border-radius: 26px;
    overflow: hidden;
    background: #fff;
    box-shadow: 0 18px 40px rgba(17, 17, 17, 0.04);
  }

  .search-result__media {
    position: relative;
    background: #f4f1ea;
  }

  .search-result__image,
  .search-result__image-placeholder {
    display: block;
    width: 100%;
    aspect-ratio: 1 / 1;
  }

  .search-result__image {
    overflow: hidden;
  }

  .search-result__image img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .search-result__image-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    color: #67615c;
    text-align: center;
    text-decoration: none;
  }

  .search-result__content {
    padding: 18px 18px 20px;
  }

  .search-result__type {
    margin: 0 0 8px;
    color: #81786d;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .search-result__title {
    margin: 0;
    color: #111;
    font-size: 1.2rem;
    line-height: 1.2;
    letter-spacing: -0.03em;
  }

  .search-result__title a {
    color: inherit;
    text-decoration: none;
  }

  .search-result__price {
    margin: 10px 0 0;
    color: #111;
    font-size: 1.28rem;
    font-weight: 700;
    letter-spacing: -0.03em;
  }

  .search-result__excerpt {
    margin: 10px 0 0;
    color: #67615c;
    font-size: 0.96rem;
    line-height: 1.7;
  }

  .search-results .prev,
  .search-results .page,
  .search-results .next {
    grid-column: 1 / -1;
  }

  @media (max-width: 749px) {
    .search-page {
      padding: 12px 0 38px;
    }

    .search-page__topbar {
      gap: 10px;
      padding: 0 14px 16px;
    }

    .search-page__back {
      width: 38px;
      height: 38px;
    }

    .search-page__topbar-field {
      min-height: 50px;
      padding: 0 18px;
      font-size: 0.98rem;
    }

    .search-page__header {
      margin-top: 22px;
      margin-bottom: 0;
      padding: 0 14px;
    }

    .search-page__intro {
      margin-top: 12px;
      font-size: 0.96rem;
    }

    .search-page__results-head {
      padding: 20px 14px 2px;
    }

    .search-page__query-title {
      font-size: 2rem;
    }

    .search-results {
      grid-template-columns: 1fr;
      gap: 16px;
      padding: 16px 14px 0;
    }

    .search-result {
      border-radius: 22px;
    }

    .search-result__content {
      padding: 16px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.search",
  "settings": []
}
{% endschema %}
