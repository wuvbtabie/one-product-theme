<section id="image-text" class="image-text-section">
  <div class="image-text-container">
    {% if section.settings.image != blank %}
      <img
        src="{{ section.settings.image | image_url: width: 1920 }}"
        alt="{{ section.settings.heading | escape }}"
        class="background-image"
      >
    {% else %}
      <img
        src="https://via.placeholder.com/1920x600?text=Your+Image"
        alt="Placeholder image"
        class="background-image"
      >
    {% endif %}
    <div class="overlay {{ section.settings.text_position }}" style="background: rgba(0,0,0,{{ section.settings.overlay_opacity }});">
      <div class="overlay-content">
        <h2>{{ section.settings.heading }}</h2>
        <p>{{ section.settings.subheading }}</p>
        {% if section.settings.button_text != blank %}
          <a href="{{ section.settings.button_link }}" class="overlay-btn">{{ section.settings.button_text }}</a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<style>
  .image-text-section {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .image-text-container {
    position: relative;
    width: 100%;
    height: 600px;
  }

  .background-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    color: #fff;
  }

  .overlay.top-left {
    align-items: flex-start;
    justify-content: flex-start;
    padding: 40px;
  }

  .overlay.center {
    align-items: center;
    justify-content: center;
  }

  .overlay.bottom-left {
    align-items: flex-end;
    justify-content: flex-start;
    padding: 40px;
  }

  .overlay-content {
    text-align: center;
    max-width: 600px;
  }

  .overlay-content h2 {
    font-size: 48px;
    margin: 0 0 20px;
    font-weight: 700;
    line-height: 1.1;
  }

  .overlay-content p {
    font-size: 24px;
    margin: 0 0 30px;
    line-height: 1.4;
  }

  .overlay-btn {
    display: inline-block;
    background: #fff;
    color: #000;
    padding: 15px 30px;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    font-size: 18px;
    transition: background 0.2s ease;
  }

  .overlay-btn:hover {
    background: #f0f0f0;
  }

  @media screen and (max-width: 768px) {
    .image-text-container {
      height: 400px;
    }

    .overlay-content h2 {
      font-size: 32px;
    }

    .overlay-content p {
      font-size: 18px;
    }

    .overlay-btn {
      padding: 12px 24px;
      font-size: 16px;
    }

    .overlay.top-left,
    .overlay.bottom-left {
      padding: 20px;
    }
  }

  @media screen and (max-width: 480px) {
    .image-text-container {
      height: 300px;
    }

    .overlay-content h2 {
      font-size: 24px;
    }

    .overlay-content p {
      font-size: 16px;
    }

    .overlay-btn {
      padding: 10px 20px;
      font-size: 14px;
    }
  }
</style>

{% schema %}
{
  "name": "Image with Text Overlay",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your Heading"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Your subheading text here."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "text_position",
      "label": "Text position",
      "options": [
        {"value": "top-left", "label": "Top Left"},
        {"value": "center", "label": "Center"},
        {"value": "bottom-left", "label": "Bottom Left"}
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0.4
    }
  ],
  "presets": [
    {
      "name": "Image with Text Overlay"
    }
  ]
}
{% endschema %}