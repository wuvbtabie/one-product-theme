{% assign pm_count = 0 %}
  {% assign pm_cols = "one" %}

{% assign media_product = blank %}
{% assign media_product = all_products['mimi-watch'] %}
{% if media_product == blank and collections.all != blank and collections.all.products_count > 0 %}
  {% assign media_product = collections.all.products.first %}
{% endif %}

{% if section.blocks.size > 0 %}
  {% for block in section.blocks %}
    {% assign block_fallback_image = blank %}
    {% if media_product != blank and media_product.images.size > forloop.index0 %}
      {% assign block_fallback_image = media_product.images[forloop.index0] %}
    {% endif %}

    {% if block.settings.type == 'image' %}
      {% if block.settings.image != blank or block_fallback_image != blank %}
        {% assign pm_count = pm_count | plus: 1 %}
      {% endif %}
    {% elsif block.settings.type == 'video' %}
      {% if block.settings.video != blank or block.settings.video_url != blank %}
        {% assign pm_count = pm_count | plus: 1 %}
      {% endif %}
    {% endif %}
  {% endfor %}
{% elsif media_product != blank and media_product.images.size > 0 %}
  {% assign pm_count = media_product.images.size %}
{% endif %}

{% if pm_count == 2 %}
  {% assign pm_cols = "two" %}
{% elsif pm_count > 2 %}
  {% assign pm_cols = "three" %}
{% endif %}

{% capture watch_360_frames %}
  {% for i in (1..24) %}
    {{ 'watch' | append: i | append: '.jpg' | asset_url }}{% unless forloop.last %},{% endunless %}
  {% endfor %}
{% endcapture %}

<section class="product-media" id="product-media">
  {% if section.settings.heading != blank %}
    <div class="product-media__header">
      <h2 class="product-media__heading">{{ section.settings.heading }}</h2>
    </div>
  {% endif %}

  <div class="product-media__grid product-media__grid--{{ pm_cols }}">
    {% if section.blocks.size > 0 %}
      {% for block in section.blocks %}
        {% assign fallback_image = blank %}
        {% if media_product != blank and media_product.images.size > forloop.index0 %}
          {% assign fallback_image = media_product.images[forloop.index0] %}
        {% endif %}
        {% assign media_image = block.settings.image | default: fallback_image %}

        {% if block.settings.type == 'image' and media_image != blank %}
          <div class="product-media__item">
            {% assign media_img_url = media_image | image_url: width: 1400 %}
            {% if media_img_url != blank and media_img_url contains '//' %}
              <img src="{{ media_img_url }}"
                   alt="{{ block.settings.alt_text | escape }}"
                   loading="lazy">
            {% else %}
              <img src="{{ media_image | img_url: '1400x' }}"
                   alt="{{ block.settings.alt_text | escape }}"
                   loading="lazy">
            {% endif %}
          </div>
        {% elsif block.settings.type == 'video' and block.settings.video != blank %}
          <div class="product-media__item product-media__item--video">
            {{ block.settings.video | video_tag: controls: true, autoplay: block.settings.video_autoplay, muted: block.settings.video_muted, loop: block.settings.video_loop, playsinline: true, image_size: '1400x' }}
          </div>
        {% elsif block.settings.type == 'video' and block.settings.video_url != blank %}
          <div class="product-media__item product-media__item--video">
            {% assign pm_ext_video = block.settings.video_url | external_video_url: autoplay: block.settings.video_autoplay, loop: block.settings.video_loop %}
            {{ pm_ext_video | external_video_tag }}
          </div>
        {% elsif block.settings.type != 'video' %}
          <div class="product-media__item product-media__item--placeholder">
            <div class="product-media__placeholder-inner">
              <span class="product-media__placeholder-icon">🖼️</span>
              <p>Upload an image in the theme editor</p>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    {% else %}
      {% if media_product != blank and media_product.images.size > 0 %}
        {% for media_image in media_product.images limit: 3 %}
          <div class="product-media__item">
            {% assign fb_img_url = media_image | image_url: width: 1400 %}
            {% if fb_img_url != blank and fb_img_url contains '//' %}
              <img src="{{ fb_img_url }}"
                   alt="{{ media_product.title | escape }}"
                   loading="lazy">
            {% else %}
              <img src="{{ media_image | img_url: '1400x' }}"
                   alt="{{ media_product.title | escape }}"
                   loading="lazy">
            {% endif %}
          </div>
        {% endfor %}
      {% else %}
        <div class="product-media__item product-media__item--placeholder">
          <div class="product-media__placeholder-inner">
            <span class="product-media__placeholder-icon">🖼️</span>
            <p>Upload your first product image</p>
          </div>
        </div>
        <div class="product-media__item product-media__item--placeholder">
          <div class="product-media__placeholder-inner">
            <span class="product-media__placeholder-icon">🖼️</span>
            <p>Add another product image</p>
          </div>
        </div>
        <div class="product-media__item product-media__item--placeholder">
          <div class="product-media__placeholder-inner">
            <span class="product-media__placeholder-icon">🎥</span>
            <p>Add a product video URL</p>
          </div>
        </div>
      {% endif %}
    {% endif %}
  </div>

  <div class="watch-360-section js-watch-360-section">
    <div class="watch-360-section__header">
      <h2 class="watch-360-section__title">In Action</h2>
      <p class="watch-360-section__subtitle">Interactive 360° View</p>
    </div>
    <div class="viewer-container">
      <div class="watch-360" data-watch-frames="{{ watch_360_frames | strip | escape }}">
        <img id="watch360" src="{{ 'watch1.jpg' | asset_url }}" alt="360 view of the watch" loading="lazy" draggable="false">
      </div>
    </div>
    <p class="watch-360__hint">Drag to rotate the watch</p>
  </div>
</section>

<script src="{{ 'watch-360-viewer.js' | asset_url }}" defer></script>

<style>
  .product-media {
    background: #ffffff;
    padding: 40px 0 48px;
  }

  .product-media__header {
    max-width: 1200px;
    margin: 0 auto 28px;
    padding: 0 20px;
    text-align: center;
  }

  .product-media__heading {
    font-size: 2rem;
    font-weight: 700;
    color: #000;
    margin: 0;
  }

  /* Grid: flush to viewport edges for single-item, padded for multi */
  .product-media__grid {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 20px;
    display: grid;
    gap: 8px;
  }

  .product-media__grid--one {
    grid-template-columns: 1fr;
    max-width: 100%;
    padding: 0;       /* no side padding — image runs edge-to-edge */
  }

  .product-media__grid--two {
    grid-template-columns: repeat(2, 1fr);
  }

  .product-media__grid--three {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  /* Items: fixed aspect ratio so images are never awkwardly cropped */
  .product-media__item {
    overflow: hidden;
    aspect-ratio: 16 / 9;
    position: relative;
    background: #f0f0f0;  /* neutral — matches white bg instead of black box */
  }

  .product-media__grid--one .product-media__item {
    aspect-ratio: 21 / 9;   /* cinematic crop for a single hero-style image */
  }

  .product-media__item img,
  .product-media__item video,
  .product-media__item iframe {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Placeholder state */
  .product-media__item--placeholder,
  .product-media__item.product-media__placeholder {
    background: #f5f5f5;
    border: 2px dashed #d0d0d0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .product-media__placeholder-inner {
    text-align: center;
    color: #999;
    padding: 20px;
  }

  .product-media__placeholder-icon {
    display: block;
    font-size: 2.5rem;
    margin-bottom: 8px;
  }

  .product-media__placeholder-inner p {
    font-size: 0.85rem;
    margin: 0;
  }

  @media (max-width: 900px) {
    .product-media__grid--three {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .product-media {
      padding: 36px 0 40px;
    }

    .product-media__heading {
      font-size: 1.6rem;
    }

    .product-media__grid--two,
    .product-media__grid--three {
      grid-template-columns: 1fr;
    }

    .product-media__grid--one .product-media__item {
      aspect-ratio: 16 / 9;
    }
  }

  .watch-360-section {
    padding: 48px 20px 56px;
    text-align: center;
    border-top: 1px solid #efefef;
    background: #fafafa;
  }

  .watch-360-section__header {
    margin-bottom: 32px;
  }

  .watch-360-section__title {
    font-size: clamp(1.7rem, 3vw, 2.4rem);
    font-weight: 700;
    color: #111;
    margin: 0 0 8px;
    letter-spacing: -0.03em;
  }

  .watch-360-section__subtitle {
    font-size: 0.9rem;
    font-weight: 500;
    color: #888;
    margin: 0;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .viewer-container {
    max-width: 600px;
    margin: 0 auto;
    display: flex;
    justify-content: center;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.1), 0 4px 16px rgba(0, 0, 0, 0.06);
    background: #f6f6f4;
    border: 1px solid #e8e8e4;
  }

  .viewer-container img {
    width: 100%;
    height: auto;
    display: block;
  }

  .watch-360 {
    width: 100%;
    user-select: none;
    touch-action: pan-y;
    cursor: grab;
  }

  .watch-360.is-dragging {
    cursor: grabbing;
  }

  .watch-360__hint {
    margin: 18px 0 0;
    font-size: 0.85rem;
    color: #888;
    letter-spacing: 0.02em;
  }

  .watch-360__hint::before {
    content: "↔";
    margin-right: 6px;
    font-size: 0.9rem;
  }

  @media (max-width: 640px) {
    .watch-360-section {
      padding: 36px 16px 44px;
    }

    .watch-360-section__header {
      margin-bottom: 24px;
    }

    .viewer-container {
      border-radius: 12px;
    }
  }
</style>

{% schema %}
{
  "name": "Product Media",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Media"
    },
    {
      "type": "checkbox",
      "id": "autoplay_video",
      "label": "Autoplay videos",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "muted_video",
      "label": "Mute videos",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "loop_video",
      "label": "Loop videos",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "media_item",
      "name": "Media item",
      "settings": [
        {
          "type": "select",
          "id": "type",
          "label": "Media type",
          "options": [
            {"value": "image", "label": "Image"},
            {"value": "video", "label": "Video"}
          ],
          "default": "image"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Gallery image",
          "info": "Upload or select an image for this slide"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Shopify hosted video"
        },
        {
          "type": "video_url",
          "id": "video_url",
          "label": "External video URL",
          "accept": ["youtube", "vimeo"],
          "info": "Paste a YouTube or Vimeo URL"
        },
        {
          "type": "text",
          "id": "alt_text",
          "label": "Image alt text",
          "default": "Product image"
        },
        {
          "type": "checkbox",
          "id": "video_autoplay",
          "label": "Autoplay video",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "video_muted",
          "label": "Mute video",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "video_loop",
          "label": "Loop video",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Media",
      "blocks": [
        {
          "type": "media_item",
          "settings": {
            "type": "image"
          }
        },
        {
          "type": "media_item",
          "settings": {
            "type": "video"
          }
        }
      ]
    }
  ]
}
{% endschema %}