{%- liquid
  assign showcase_product = blank
  assign showcase_product_setting = section.settings.product

  if showcase_product_setting != blank
    assign showcase_product = showcase_product_setting
    unless showcase_product.title
      assign showcase_product = all_products[showcase_product_setting]
    endunless
  endif

  if showcase_product == blank and section.settings.button_link contains '/products/'
    assign showcase_product_handle = section.settings.button_link | split: '/products/' | last | split: '?' | first | split: '#' | first
    assign showcase_product = all_products[showcase_product_handle]
  endif

  if showcase_product == blank and collections.all != blank and collections.all.products_count > 0
    assign showcase_product = collections.all.products.first
  endif

  assign display_variant = nil
  assign product_image = blank
  assign current_variant = nil

  if showcase_product != blank
    assign current_variant = showcase_product.selected_or_first_available_variant
    assign display_variant = current_variant | default: showcase_product.variants.first
    assign product_image = showcase_product.featured_image
  endif

  assign showcase_img = section.settings.custom_image
  if showcase_img == blank and product_image != blank
    assign showcase_img = product_image
  endif

  assign has_showcase_img = false
  if showcase_img != blank
    assign has_showcase_img = true
  endif

  assign showcase_cta_url = section.settings.button_link | default: '/collections/all'
  if showcase_product != blank and showcase_product.url != blank
    assign showcase_cta_url = showcase_product.url
  endif
-%}

<section class="product-showcase" id="product-showcase" style="background: {{ section.settings.background_color }};">
  <div class="product-showcase__inner product-showcase__inner--{{ section.settings.image_position }}">

    <div class="product-showcase__media">
      {% if has_showcase_img %}
        {% assign showcase_img_url = showcase_img | image_url: width: 900 %}
        {% if showcase_img_url != blank and showcase_img_url contains '//' %}
          <img class="product-showcase__img"
               src="{{ showcase_img_url }}"
               srcset="{{ showcase_img | image_url: width: 450 }} 450w, {{ showcase_img_url }} 900w, {{ showcase_img | image_url: width: 1200 }} 1200w"
               sizes="(max-width: 768px) 100vw, 50vw"
               alt="{{ showcase_img.alt | default: section.settings.heading | escape }}"
               loading="lazy"
               width="{{ showcase_img.width | default: 900 }}"
               height="{{ showcase_img.height | default: 900 }}">
        {% else %}
          <img class="product-showcase__img"
               src="{{ showcase_img | img_url: '900x' }}"
               alt="{{ section.settings.heading | escape }}"
               loading="lazy"
               width="900"
               height="900">
        {% endif %}
      {% else %}
        <div class="product-showcase__img-placeholder">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1.5" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/>
          </svg>
          <p>Product image will appear here automatically.</p>
        </div>
      {% endif %}
    </div>

    <div class="product-showcase__details">

      {% comment %} Badge: custom text OR auto-calculated sale {% endcomment %}
      {% if section.settings.badge_text != blank %}
        <span class="product-showcase__badge">{{ section.settings.badge_text }}</span>
      {% elsif current_variant and current_variant.compare_at_price > current_variant.price %}
        {% assign savings_cents = current_variant.compare_at_price | minus: current_variant.price %}
        {% assign savings_pct = savings_cents | times: 100 | divided_by: current_variant.compare_at_price %}
        <span class="product-showcase__badge product-showcase__badge--sale">{{ savings_pct }}% Off</span>
      {% endif %}

      {% comment %} Title {% endcomment %}
      <h2 class="product-showcase__title">
        {% if section.settings.heading != blank %}
          {{ section.settings.heading }}
        {% elsif showcase_product %}
          {{ showcase_product.title }}
        {% else %}
          Featured Product
        {% endif %}
      </h2>

      {% comment %} Description {% endcomment %}
      {% if section.settings.custom_description != blank %}
        <div class="product-showcase__description">{{ section.settings.custom_description }}</div>
      {% elsif showcase_product and showcase_product.description != blank %}
        <div class="product-showcase__description product-showcase__description--product">
          {{ showcase_product.description | strip_html | truncate: 260 }}
        </div>
      {% else %}
        <div class="product-showcase__description">
          A refined everyday timepiece with clean lines, durable materials, and a comfortable fit designed for modern wear.
        </div>
      {% endif %}

      {% if display_variant %}
        <div class="product-showcase__cta-meta">
          <div class="product-showcase__price-row">
            <span class="product-showcase__price">${{ display_variant.price | money_without_currency }}</span>
            {% if display_variant.compare_at_price > display_variant.price %}
              <s class="product-showcase__compare-price">${{ display_variant.compare_at_price | money_without_currency }}</s>
            {% endif %}
          </div>
        </div>
      {% endif %}

      {% comment %} CTA {% endcomment %}
      {% if showcase_product and display_variant %}
        {% form 'product', showcase_product, id: 'product-showcase-form' %}
          <input type="hidden" name="id" value="{{ display_variant.id }}">
          {% if showcase_product.variants.size > 1 %}
            <div class="product-showcase__variants">
              {% for variant in showcase_product.variants %}
                <button
                  type="button"
                  class="product-showcase__variant-btn{% if variant.id == display_variant.id %} is-selected{% endif %}"
                  data-variant-id="{{ variant.id }}"
                  data-variant-price="{{ variant.price }}"
                  data-variant-compare="{{ variant.compare_at_price }}"
                  {% unless variant.available %}aria-disabled="true"{% endunless %}
                >{{ variant.title }}</button>
              {% endfor %}
            </div>
          {% endif %}
          <div class="product-showcase__actions">
            <button type="submit" name="add" class="product-showcase__btn">
              {{ section.settings.button_text | default: "Add to Cart" }}
            </button>
            {% render 'wishlist-button',
              class: 'product-favorite-button',
              title: showcase_product.title,
              url: showcase_product.url,
              image: showcase_product.featured_image,
              price: display_variant.price,
              handle: showcase_product.handle,
              product_id: showcase_product.id
            %}
          </div>
        {% endform %}
      {% else %}
        <a href="{{ showcase_cta_url }}" class="product-showcase__btn">
          {{ section.settings.button_text | default: "View Product" }}
        </a>
      {% endif %}

    </div>
  </div>
</section>

<style>
  .product-showcase {
    padding: 80px 20px;
  }

  .product-showcase__inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .product-showcase__inner--right .product-showcase__media {
    order: 2;
  }

  .product-showcase__inner--right .product-showcase__details {
    order: 1;
  }

  /* Image column */
  .product-showcase__media {
    position: relative;
  }

  .product-showcase__img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    aspect-ratio: 1 / 1;
  }

  .product-showcase__img-placeholder {
    aspect-ratio: 1 / 1;
    background: #f0f0f0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    color: #aaa;
    font-size: 0.875rem;
  }

  /* Details column */
  .product-showcase__details {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
  }

  .product-showcase__badge {
    display: inline-block;
    background: #000;
    color: #fff;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 5px 14px;
    margin-bottom: 18px;
  }

  .product-showcase__badge--sale {
    background: #c8242e;
  }

  .product-showcase__title {
    font-size: 2.2rem;
    font-weight: 800;
    color: #000;
    line-height: 1.15;
    margin: 0 0 18px;
    letter-spacing: -0.02em;
  }

  .product-showcase__price-row {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 22px;
  }

  .product-showcase__price {
    font-size: 1.6rem;
    font-weight: 700;
    color: #000;
    letter-spacing: -0.01em;
  }

  .product-showcase__compare-price {
    font-size: 1rem;
    color: #999;
    font-weight: 400;
    text-decoration: line-through;
  }

  .product-showcase__description {
    color: #555;
    font-size: 0.95rem;
    line-height: 1.75;
    margin-bottom: 32px;
    max-width: 460px;
  }

  .product-showcase__cta-meta {
    margin-bottom: 16px;
  }

  .product-showcase__btn {
    display: block;
    width: 100%;
    background: #000;
    color: #fff;
    border: 2px solid #000;
    padding: 16px 40px;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    text-decoration: none;
    text-align: center;
    transition: background 0.2s ease, color 0.2s ease;
    appearance: none;
    -webkit-appearance: none;
    box-sizing: border-box;
  }

  .product-showcase__btn:hover {
    background: #fff;
    color: #000;
  }

  @media (max-width: 800px) {
    .product-showcase {
      padding: 56px 20px;
    }

    .product-showcase__inner {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .product-showcase__inner--right .product-showcase__media,
    .product-showcase__inner--right .product-showcase__details {
      order: unset;
    }

    .product-showcase__title {
      font-size: 1.7rem;
    }

    .product-showcase__price {
      font-size: 1.35rem;
    }

    .product-showcase__description {
      max-width: 100%;
    }
  }
</style>

<script>
(function () {
  function formatMoney(cents) {
    var amount = Number(cents || 0) / 100;
    var locale = 'en-US';
    var currency = 'USD';

    try {
      return new Intl.NumberFormat(locale, { style: 'currency', currency: currency }).format(amount);
    } catch (error) {
      return amount.toFixed(2) + ' ' + currency;
    }
  }

  var form = document.getElementById('product-showcase-form');
  if (!form) return;
  form.addEventListener('click', function (e) {
    var btn = e.target.closest('.product-showcase__variant-btn');
    if (!btn || btn.getAttribute('aria-disabled') === 'true') return;
    form.querySelector('[name="id"]').value = btn.dataset.variantId;
    form.querySelectorAll('.product-showcase__variant-btn').forEach(function (b) {
      b.classList.toggle('is-selected', b === btn);
    });
    var section = form.closest('.product-showcase__inner');
    if (!section) return;
    var priceEl = section.querySelector('.product-showcase__price');
    var compareEl = section.querySelector('.product-showcase__compare-price');
    var rawPrice = parseInt(btn.dataset.variantPrice || '0', 10);
    var rawCompare = parseInt(btn.dataset.variantCompare || '0', 10);
    if (priceEl) priceEl.textContent = formatMoney(rawPrice);
    if (compareEl) {
      if (rawCompare > rawPrice) {
        compareEl.textContent = formatMoney(rawCompare);
        compareEl.style.display = '';
      } else {
        compareEl.style.display = 'none';
      }
    }
  });
})();
</script>

{% schema %}
{
  "name": "Product Showcase",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Select product",
      "info": "Connect to live Shopify product data for title, price, and image"
    },
    {
      "type": "image_picker",
      "id": "custom_image",
      "label": "Custom image",
      "info": "Overrides the product image if selected"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "info": "Overrides the product title if filled in"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "placeholder": "Best Seller"
    },
    {
      "type": "richtext",
      "id": "custom_description",
      "label": "Custom description",
      "info": "Overrides the product description if filled in"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Add to Cart"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link",
      "info": "Used as fallback when no product is selected",
      "default": "/collections/all"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image side",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f8f8f8"
    }
  ],
  "presets": [
    {
      "name": "Product Showcase"
    }
  ]
}
{% endschema %}
