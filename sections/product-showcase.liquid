{% assign showcase_product = section.settings.product %}
{% if showcase_product == blank and section.settings.button_link contains '/products/' %}
  {% assign showcase_product_handle = section.settings.button_link | split: '/products/' | last | split: '?' | first | split: '#' | first %}
  {% assign showcase_product = all_products[showcase_product_handle] %}
{% endif %}
{% assign display_variant = nil %}
{% if showcase_product %}
  {% assign current_variant = showcase_product.selected_or_first_available_variant %}
  {% assign display_variant = current_variant | default: showcase_product.variants.first %}
  {% assign product_image = showcase_product.featured_image %}
{% endif %}

{% assign showcase_img = section.settings.custom_image %}
{% if showcase_img == blank and product_image %}
  {% assign showcase_img = product_image %}
{% endif %}

<section class="product-showcase" id="product-showcase" style="background: {{ section.settings.background_color }};">
  <div class="product-showcase__inner product-showcase__inner--{{ section.settings.image_position }}">

    <div class="product-showcase__media">
      {% if showcase_img %}
        <img class="product-showcase__img"
             src="{{ showcase_img | image_url: width: 900 }}"
             srcset="{{ showcase_img | image_url: width: 450 }} 450w, {{ showcase_img | image_url: width: 900 }} 900w, {{ showcase_img | image_url: width: 1200 }} 1200w"
             sizes="(max-width: 768px) 100vw, 50vw"
             alt="{{ showcase_img.alt | default: section.settings.heading | escape }}"
             loading="lazy"
             width="{{ showcase_img.width }}"
             height="{{ showcase_img.height }}">
      {% else %}
        <div class="product-showcase__img-placeholder">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1.5" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/>
          </svg>
          <p>Select a product or upload an image</p>
        </div>
      {% endif %}
    </div>

    <div class="product-showcase__details">

      {% comment %} Badge: custom text OR auto-calculated sale % {% endcomment %}
      {% if section.settings.badge_text != blank %}
        <span class="product-showcase__badge">{{ section.settings.badge_text }}</span>
      {% elsif current_variant and current_variant.compare_at_price > current_variant.price %}
        {% assign savings_cents = current_variant.compare_at_price | minus: current_variant.price %}
        {% assign savings_pct = savings_cents | times: 100 | divided_by: current_variant.compare_at_price %}
        <span class="product-showcase__badge product-showcase__badge--sale">{{ savings_pct }}% Off</span>
      {% endif %}

      {% comment %} Title {% endcomment %}
      <h2 class="product-showcase__title">
        {% if section.settings.heading != blank %}
          {{ section.settings.heading }}
        {% elsif showcase_product %}
          {{ showcase_product.title }}
        {% else %}
          Featured Product
        {% endif %}
      </h2>

      {% comment %} Description {% endcomment %}
      {% if section.settings.custom_description != blank %}
        <div class="product-showcase__description">{{ section.settings.custom_description }}</div>
      {% elsif showcase_product and showcase_product.description != blank %}
        <div class="product-showcase__description product-showcase__description--product">
          {{ showcase_product.description | strip_html | truncate: 260 }}
        </div>
      {% endif %}

      {% if display_variant %}
        <div class="product-showcase__cta-meta">
          <div class="product-showcase__price-row">
            <span class="product-showcase__price">{{ display_variant.price | money }}</span>
            {% if display_variant.compare_at_price > display_variant.price %}
              <s class="product-showcase__compare-price">{{ display_variant.compare_at_price | money }}</s>
            {% endif %}
          </div>
        </div>
      {% endif %}

      {% comment %} CTA {% endcomment %}
      {% if showcase_product and display_variant %}
        {% form 'product', showcase_product, id: 'product-showcase-form' %}
          <input type="hidden" name="id" value="{{ display_variant.id }}">
          <button type="submit" name="add" class="product-showcase__btn">
            {{ section.settings.button_text | default: "Add to Cart" }}
          </button>
        {% endform %}
      {% else %}
        <a href="{{ section.settings.button_link | default: '/collections/all' }}" class="product-showcase__btn">
          {{ section.settings.button_text | default: "Shop Now" }}
        </a>
      {% endif %}

    </div>
  </div>
</section>

<style>
  .product-showcase {
    padding: 80px 20px;
  }

  .product-showcase__inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .product-showcase__inner--right .product-showcase__media {
    order: 2;
  }

  .product-showcase__inner--right .product-showcase__details {
    order: 1;
  }

  /* Image column */
  .product-showcase__media {
    position: relative;
  }

  .product-showcase__img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    aspect-ratio: 1 / 1;
  }

  .product-showcase__img-placeholder {
    aspect-ratio: 1 / 1;
    background: #f0f0f0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    color: #aaa;
    font-size: 0.875rem;
  }

  /* Details column */
  .product-showcase__details {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
  }

  .product-showcase__badge {
    display: inline-block;
    background: #000;
    color: #fff;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 5px 14px;
    margin-bottom: 18px;
  }

  .product-showcase__badge--sale {
    background: #c8242e;
  }

  .product-showcase__title {
    font-size: 2.2rem;
    font-weight: 800;
    color: #000;
    line-height: 1.15;
    margin: 0 0 18px;
    letter-spacing: -0.02em;
  }

  .product-showcase__price-row {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 22px;
  }

  .product-showcase__price {
    font-size: 1.6rem;
    font-weight: 700;
    color: #000;
    letter-spacing: -0.01em;
  }

  .product-showcase__compare-price {
    font-size: 1rem;
    color: #999;
    font-weight: 400;
    text-decoration: line-through;
  }

  .product-showcase__description {
    color: #555;
    font-size: 0.95rem;
    line-height: 1.75;
    margin-bottom: 32px;
    max-width: 460px;
  }

  .product-showcase__cta-meta {
    margin-bottom: 16px;
  }

  .product-showcase__btn {
    display: block;
    width: 100%;
    background: #000;
    color: #fff;
    border: 2px solid #000;
    padding: 16px 40px;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    text-decoration: none;
    text-align: center;
    transition: background 0.2s ease, color 0.2s ease;
    appearance: none;
    -webkit-appearance: none;
    box-sizing: border-box;
  }

  .product-showcase__btn:hover {
    background: #fff;
    color: #000;
  }

  @media (max-width: 800px) {
    .product-showcase {
      padding: 56px 20px;
    }

    .product-showcase__inner {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .product-showcase__inner--right .product-showcase__media,
    .product-showcase__inner--right .product-showcase__details {
      order: unset;
    }

    .product-showcase__title {
      font-size: 1.7rem;
    }

    .product-showcase__price {
      font-size: 1.35rem;
    }

    .product-showcase__description {
      max-width: 100%;
    }
  }
</style>

{% schema %}
{
  "name": "Product Showcase",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Select product",
      "info": "Connect to live Shopify product data for title, price, and image"
    },
    {
      "type": "image_picker",
      "id": "custom_image",
      "label": "Custom image",
      "info": "Overrides the product image if selected"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "info": "Overrides the product title if filled in"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "placeholder": "Best Seller"
    },
    {
      "type": "richtext",
      "id": "custom_description",
      "label": "Custom description",
      "info": "Overrides the product description if filled in"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Add to Cart"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link",
      "info": "Used as fallback when no product is selected",
      "default": "/collections/all"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image side",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f8f8f8"
    }
  ],
  "presets": [
    {
      "name": "Product Showcase"
    }
  ]
}
{% endschema %}
