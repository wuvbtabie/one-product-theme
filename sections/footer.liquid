<footer class="footer" style="background-color: {{ section.settings.background_color }}; color: {{ section.settings.text_color }};">
  <div class="footer__content">
    <div class="footer__column footer__column--about">
      <h3 class="footer__title">{{ section.settings.store_name }}</h3>
      <p class="footer__description">{{ section.settings.store_description }}</p>

      {% capture footer_social_links %}
        {% for block in section.blocks %}
          {% assign social_url = block.settings.url | strip | downcase %}
          {% assign is_placeholder_social = false %}
          {% if social_url == 'https://instagram.com' or social_url == 'https://www.instagram.com' or social_url == 'https://tiktok.com' or social_url == 'https://www.tiktok.com' or social_url == 'https://facebook.com' or social_url == 'https://www.facebook.com' %}
            {% assign is_placeholder_social = true %}
          {% endif %}

          {% if block.settings.url != blank and is_placeholder_social == false %}
            <a href="{{ block.settings.url }}" class="footer__social-link" target="_blank" rel="noopener" aria-label="{{ block.settings.platform }}">
              <span aria-hidden="true">{{ block.settings.icon }}</span>
            </a>
          {% endif %}
        {% endfor %}
      {% endcapture %}

      {% if footer_social_links != blank %}
        <div class="footer__social-links" aria-label="Social media links">
          {{ footer_social_links }}
        </div>
      {% endif %}
    </div>

    <div class="footer__column">
      <h4 class="footer__heading">{{ section.settings.col2_heading }}</h4>
      <ul class="footer__list">
        {% if section.settings.link1_text != blank and section.settings.link1_url != blank %}
          <li><a href="{{ section.settings.link1_url }}">{{ section.settings.link1_text }}</a></li>
        {% endif %}
        {% if section.settings.link2_text != blank and section.settings.link2_url != blank %}
          <li><a href="{{ section.settings.link2_url }}">{{ section.settings.link2_text }}</a></li>
        {% endif %}
        {% if section.settings.link3_text != blank and section.settings.link3_url != blank %}
          <li><a href="{{ section.settings.link3_url }}">{{ section.settings.link3_text }}</a></li>
        {% endif %}
      </ul>
    </div>

    <div class="footer__column">
      <h4 class="footer__heading">{{ section.settings.col3_heading }}</h4>
      <ul class="footer__list">
        {% if section.settings.link4_text != blank and section.settings.link4_url != blank %}
          <li><a href="{{ section.settings.link4_url }}">{{ section.settings.link4_text }}</a></li>
        {% endif %}
        {% if section.settings.link5_text != blank and section.settings.link5_url != blank %}
          <li><a href="{{ section.settings.link5_url }}">{{ section.settings.link5_text }}</a></li>
        {% endif %}
        {% if section.settings.link6_text != blank and section.settings.link6_url != blank %}
          <li><a href="{{ section.settings.link6_url }}">{{ section.settings.link6_text }}</a></li>
        {% endif %}
      </ul>
    </div>

    <div class="footer__column footer__column--newsletter">
      <h4 class="footer__heading">{{ section.settings.newsletter_heading }}</h4>
      <p class="footer__newsletter-text">{{ section.settings.newsletter_text }}</p>

      {% form 'customer', class: 'footer__newsletter-form' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <label for="FooterNewsletterEmail-{{ section.id }}" class="sr-only">Email</label>
        <div class="footer__newsletter-row">
          <input
            id="FooterNewsletterEmail-{{ section.id }}"
            type="email"
            name="contact[email]"
            class="footer__newsletter-input"
            placeholder="{{ section.settings.newsletter_placeholder }}"
            autocomplete="email"
            required
          >
          <button type="submit" class="footer__newsletter-button">{{ section.settings.newsletter_button_text }}</button>
        </div>

        {% if form.posted_successfully? %}
          <p class="footer__newsletter-message footer__newsletter-message--success">Thanks for subscribing.</p>
        {% endif %}

        {% if form.errors %}
          <p class="footer__newsletter-message footer__newsletter-message--error">Please enter a valid email address.</p>
        {% endif %}
      {% endform %}
    </div>
  </div>

  <div class="footer__bottom">
    <div class="footer__policy-links">
      {% if section.settings.policy_privacy_url != blank %}
        <a href="{{ section.settings.policy_privacy_url }}">{{ section.settings.policy_privacy_text }}</a>
      {% endif %}
      {% if section.settings.policy_shipping_url != blank %}
        <a href="{{ section.settings.policy_shipping_url }}">{{ section.settings.policy_shipping_text }}</a>
      {% endif %}
      {% if section.settings.policy_returns_url != blank %}
        <a href="{{ section.settings.policy_returns_url }}">{{ section.settings.policy_returns_text }}</a>
      {% endif %}
    </div>

    <p class="footer__copyright">{{ section.settings.copyright_text }}</p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid {{ section.settings.divider_color }};
    padding: 72px 16px 28px;
  }

  .footer__content {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 34px;
    padding-bottom: 40px;
          grid-template-columns: repeat(2, minmax(0, 1fr));
          gap: 24px 18px;

  .footer__title {
    margin: 0 0 14px;
    font-size: 1.1rem;
    line-height: 1.2;
    letter-spacing: -0.2px;
    color: {{ section.settings.text_color }};
  }

  .footer__heading {
    margin: 0 0 14px;
    font-size: 0.95rem;
    line-height: 1.3;
    letter-spacing: 0.3px;
    text-transform: uppercase;
    color: {{ section.settings.text_color }};
  }

  .footer__description,
  .footer__newsletter-text {
    margin: 0;
    opacity: 0.82;
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .footer__social-links {
    margin-top: 18px;
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .footer__social-link {
    width: 34px;
    height: 34px;
    border-radius: 999px;
    border: 1px solid #d8d8d8;
    background: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    font-size: 15px;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .footer__social-link:hover {
    background: #f4f4f4;
    transform: translateY(-1px);
  }

  .footer__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer__list a,
  .footer__policy-links a {
    color: {{ section.settings.text_color }};
    opacity: 0.84;
    text-decoration: none;
    font-size: 0.9rem;
    line-height: 1.5;
    transition: opacity 0.2s ease;
  }

  .footer__list a:hover,
  .footer__policy-links a:hover {
    opacity: 1;
  }

  .footer__newsletter-form {
    margin-top: 14px;
  }

  .footer__newsletter-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 8px;
  }

  .footer__newsletter-input {
    height: 40px;
    border: 1px solid #d9d9d9;
    border-radius: 9px;
    padding: 0 12px;
    font-size: 14px;
    background: #fff;
    color: #111;
  }

  .footer__newsletter-input:focus {
    outline: none;
    border-color: #111;
  }

  .footer__newsletter-button {
    height: 40px;
    border: 1px solid #111;
    background: #111;
    color: #fff;
    border-radius: 9px;
    padding: 0 14px;
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
  }

  .footer__newsletter-message {
    margin: 10px 0 0;
    font-size: 0.82rem;
  }

  .footer__newsletter-message--success {
    color: #0d6d2f;
  }

  .footer__newsletter-message--error {
    color: #9f1a1a;
  }

  .footer__bottom {
    max-width: 1200px;
    margin: 0 auto;
    border-top: 1px solid {{ section.settings.divider_color }};
    padding-top: 18px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer__policy-links {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    align-items: center;
  }

  .footer__policy-links a {
    position: relative;
  }

  .footer__policy-links a:not(:last-child)::after {
    content: "";
    position: absolute;
    right: -8px;
    top: 50%;
    width: 1px;
    height: 12px;
    background: rgba(17, 17, 17, 0.16);
    transform: translateY(-50%);
  }

  .footer__copyright {
    margin: 0;
    font-size: 0.8rem;
    line-height: 1.5;
    opacity: 0.72;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (min-width: 900px) {
    .footer {
      padding: 84px 24px 30px;
    }

    .footer__content {
      grid-template-columns: 1.2fr 1fr 1fr 1.2fr;
      gap: 36px;
      padding-bottom: 48px;
    }

    .footer__title {
      font-size: 1.2rem;
    }

    .footer__heading {
      font-size: 0.9rem;
      margin-bottom: 16px;
    }

    .footer__bottom {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
      gap: 20px;
    }
  }

  @media (max-width: 640px) {
    .footer {
      padding: 56px 16px 24px;
    }

    .footer__content {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 24px 18px;
      padding-bottom: 30px;
    }

    .footer__column--about,
    .footer__column--newsletter {
      grid-column: 1 / -1;
    }

    .footer__column--newsletter {
      max-width: 520px;
      margin: 0 auto;
      text-align: center;
    }

    .footer__column {
      min-width: 0;
    }

    .footer__heading {
      margin-bottom: 12px;
    }

    .footer__list {
      gap: 8px;
    }

    .footer__newsletter-row {
      grid-template-columns: 1fr;
      max-width: 360px;
      margin: 0 auto;
    }

    .footer__newsletter-button {
      width: 100%;
    }

    .footer__newsletter-text {
      max-width: 28ch;
      margin: 0 auto;
    }

    .footer__bottom {
      align-items: center;
      text-align: center;
      gap: 12px;
    }

    .footer__policy-links {
      justify-content: center;
      gap: 18px;
    }
  }

  @media (max-width: 420px) {
    .footer__content {
      grid-template-columns: 1fr;
      gap: 22px;
    }

    .footer__column--newsletter {
      max-width: none;
      text-align: left;
    }

    .footer__newsletter-text {
      max-width: none;
      margin: 0;
    }

    .footer__newsletter-row {
      max-width: none;
      margin: 0;
    }

    .footer__bottom {
      align-items: flex-start;
      text-align: left;
    }

    .footer__policy-links {
      justify-content: flex-start;
      gap: 14px;
    }
  }
</style>

