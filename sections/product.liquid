{% comment %}
  This section is used in the product template to render product page with
  media, content, and add-to-cart form.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/product
{% endcomment %}

<div class="product-images product-gallery" data-product-gallery>
  <div class="product-gallery__viewport">
    <div class="product-gallery__track" data-product-gallery-track>
      {% for image in product.images %}
        <div class="product-gallery__slide{% if forloop.first %} is-active{% endif %}" data-product-gallery-slide>
          {% render 'image', class: 'product-image product-gallery__image', image: image %}
        </div>
      {% endfor %}
    </div>
  </div>

  {% if product.images.size > 1 %}
    <div class="product-gallery__controls">
      <button type="button" class="product-gallery__arrow product-gallery__arrow--prev" data-gallery-prev aria-label="Previous image">
        <span aria-hidden="true">&#8249;</span>
      </button>

      <div class="product-gallery__dots" aria-label="Product image navigation">
        {% for image in product.images %}
          <button
            type="button"
            class="product-gallery__dot{% if forloop.first %} is-active{% endif %}"
            data-gallery-dot
            data-gallery-index="{{ forloop.index0 }}"
            aria-label="Go to image {{ forloop.index }}"
            {% if forloop.first %}
              aria-current="true"
            {% endif %}
          ></button>
        {% endfor %}
      </div>

      <button type="button" class="product-gallery__arrow product-gallery__arrow--next" data-gallery-next aria-label="Next image">
        <span aria-hidden="true">&#8250;</span>
      </button>
    </div>
  {% endif %}
</div>

<div class="product-info">
  <div class="product-info__head">
    <h1>{{ product.title }}</h1>
    {% render 'wishlist-button',
      product: product,
      class: 'wishlist-inline-button'
    %}
  </div>
  <p>${{ product.price | money_without_currency }}</p>
  <p>{{ product.description }}</p>
</div>

<div class="product-form">
  {% form 'product', product %}
    {% assign current_variant = product.selected_or_first_available_variant %}

    {% if product.variants.size > 1 %}
      <div class="product-form__field product-form__field--variant">
        <label class="product-form__label" for="product-variant-select">Options</label>
        <div class="product-form__select-wrap">
          <select id="product-variant-select" name="id" class="product-form__select">
            {% for variant in product.variants %}
              <option
                value="{{ variant.id }}"
                {% if variant == current_variant %}
                  selected="selected"
                {% endif %}
              >
                {{ variant.title }} - ${{ variant.price | money_without_currency }}
              </option>
            {% endfor %}
          </select>
        </div>
      </div>
    {% else %}
      <input type="hidden" name="id" value="{{ current_variant.id }}">
    {% endif %}

    <div class="product-form__purchase-group">
      <div class="product-form__field product-form__field--quantity">
        <label class="product-form__label" for="product-quantity">Quantity</label>
        <input id="product-quantity" class="product-form__quantity" type="number" name="quantity" min="1" value="1" aria-label="Quantity">
      </div>

      <input type="submit" value="Add to cart" class="primary-add-to-cart">
    </div>

    <div class="product-form__payment-wrap">
      {{ form | payment_button }}
    </div>
  {% endform %}

  <div class="sticky-add-to-cart" aria-hidden="true">
    <div class="sticky-add-to-cart__inner">
      <span class="sticky-add-to-cart__price">${{ current_variant.price | money_without_currency }}</span>
      <button type="button" class="sticky-add-to-cart__button">Add to cart</button>
    </div>
  </div>
</div>

<style>
  .product-gallery {
    display: grid;
    gap: 14px;
  }

  .product-gallery__viewport {
    position: relative;
    overflow: hidden;
    border-radius: 18px;
    background: #f6f3ec;
  }

  .product-gallery__track {
    display: flex;
    transition: transform 0.3s ease;
    will-change: transform;
    touch-action: pan-y;
  }

  .product-gallery__slide {
    min-width: 100%;
    flex: 0 0 100%;
  }

  .product-gallery__image,
  .product-gallery__image > img {
    display: block;
    width: 100%;
  }

  .product-gallery__image > img {
    aspect-ratio: 4 / 5;
    object-fit: contain;
    object-position: center;
    background: #f6f3ec;
  }

  .product-gallery__controls {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .product-gallery__arrow {
    width: 42px;
    height: 42px;
    border: 1px solid #ddd6cb;
    border-radius: 999px;
    background: #fff;
    color: #111;
    font: inherit;
    font-size: 1.4rem;
    line-height: 1;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .product-gallery__dots {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    flex: 1;
  }

  .product-gallery__dot {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    border: none;
    background: #d0c8bc;
    padding: 0;
    cursor: pointer;
    transition: transform 0.18s ease, background 0.18s ease;
  }

  .product-gallery__dot.is-active {
    background: #111;
    transform: scale(1.15);
  }

  .product-form form {
    display: grid;
    gap: 16px;
    margin-top: 22px;
  }

  .product-form__field {
    display: grid;
    gap: 8px;
  }

  .product-form__label {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #6c665f;
  }

  .product-form__select-wrap {
    position: relative;
  }

  .product-form__select-wrap::after {
    content: "";
    position: absolute;
    top: 50%;
    right: 18px;
    width: 10px;
    height: 10px;
    border-right: 1.5px solid #111;
    border-bottom: 1.5px solid #111;
    transform: translateY(-65%) rotate(45deg);
    pointer-events: none;
  }

  .product-form__select,
  .product-form__quantity {
    width: 100%;
    min-height: 52px;
    border: 1px solid #ddd6cb;
    border-radius: 16px;
    background: #fbfaf7;
    color: #111;
    font: inherit;
    padding: 0 18px;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.8);
  }

  .product-form__select {
    appearance: none;
    padding-right: 48px;
  }

  .product-form__quantity {
    max-width: 112px;
    text-align: center;
    font-weight: 700;
  }

  .product-form__purchase-group {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 14px;
    align-items: end;
  }

  .primary-add-to-cart {
    width: 100%;
    min-height: 54px;
    border: none;
    border-radius: 16px;
    background: #111;
    color: #fff;
    font: inherit;
    font-weight: 700;
    letter-spacing: 0.01em;
    cursor: pointer;
    transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
  }

  .primary-add-to-cart:hover {
    background: #1d1d1d;
    transform: translateY(-1px);
    box-shadow: 0 12px 24px rgba(17, 17, 17, 0.14);
  }

  .product-form__payment-wrap {
    display: grid;
    gap: 8px;
  }

  .product-form .shopify-payment-button {
    margin-top: 2px;
  }

  .product-form .shopify-payment-button__button {
    min-height: 46px !important;
    border-radius: 14px !important;
    overflow: hidden;
  }

  .product-form .shopify-payment-button__more-options {
    margin-top: 8px !important;
    font-size: 0.88rem !important;
    color: #5f5a56 !important;
  }

  .product-info__head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
  }

  .product-info__head h1 {
    margin: 0;
  }

  .product-info .wishlist-inline-button {
    margin-top: 2px;
  }

  .sticky-add-to-cart {
    position: fixed;
    left: 0;
    right: 0;
    bottom: -80px;
    background: #000;
    color: #fff;
    padding: 12px 16px;
    box-shadow: 0 -4px 16px rgba(0,0,0,0.2);
    transition: transform 0.25s ease, opacity 0.25s ease;
    transform: translateY(100%);
    opacity: 0;
    z-index: 220;
  }

  .sticky-add-to-cart.open {
    transform: translateY(0);
    opacity: 1;
  }

  .sticky-add-to-cart__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
  }

  .sticky-add-to-cart__price {
    font-weight: 700;
    font-size: 1rem;
  }

  .sticky-add-to-cart__button {
    background: #fff;
    color: #000;
    padding: 10px 16px;
    border: none;
    border-radius: 8px;
    font-weight: 700;
    cursor: pointer;
  }

  @media (min-width: 769px) {
    .sticky-add-to-cart { display: none; }
  }

  @media (max-width: 640px) {
    .product-gallery {
      gap: 10px;
    }

    .product-gallery__viewport {
      border-radius: 14px;
    }

    .product-gallery__arrow {
      width: 38px;
      height: 38px;
    }

    .product-form form {
      gap: 14px;
    }

    .product-form__purchase-group {
      grid-template-columns: 96px minmax(0, 1fr);
      gap: 10px;
    }

    .product-form__select,
    .product-form__quantity,
    .primary-add-to-cart {
      min-height: 50px;
      border-radius: 14px;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var gallery = document.querySelector('[data-product-gallery]');
    if (gallery) {
      var track = gallery.querySelector('[data-product-gallery-track]');
      var slides = Array.prototype.slice.call(gallery.querySelectorAll('[data-product-gallery-slide]'));
      var dots = Array.prototype.slice.call(gallery.querySelectorAll('[data-gallery-dot]'));
      var prevButton = gallery.querySelector('[data-gallery-prev]');
      var nextButton = gallery.querySelector('[data-gallery-next]');
      var currentIndex = 0;
      var startX = 0;
      var deltaX = 0;
      var isDragging = false;

      function updateGallery(index) {
        if (!track || !slides.length) return;

        currentIndex = Math.max(0, Math.min(index, slides.length - 1));
        track.style.transform = 'translate3d(' + (currentIndex * -100) + '%, 0, 0)';

        slides.forEach(function (slide, slideIndex) {
          slide.classList.toggle('is-active', slideIndex === currentIndex);
        });

        dots.forEach(function (dot, dotIndex) {
          var isActive = dotIndex === currentIndex;
          dot.classList.toggle('is-active', isActive);
          if (isActive) {
            dot.setAttribute('aria-current', 'true');
          } else {
            dot.removeAttribute('aria-current');
          }
        });
      }

      if (prevButton) {
        prevButton.addEventListener('click', function () {
          updateGallery(currentIndex - 1 < 0 ? slides.length - 1 : currentIndex - 1);
        });
      }

      if (nextButton) {
        nextButton.addEventListener('click', function () {
          updateGallery(currentIndex + 1 > slides.length - 1 ? 0 : currentIndex + 1);
        });
      }

      dots.forEach(function (dot) {
        dot.addEventListener('click', function () {
          updateGallery(parseInt(dot.getAttribute('data-gallery-index') || '0', 10));
        });
      });

      if (track && slides.length > 1) {
        track.addEventListener('touchstart', function (event) {
          startX = event.touches[0].clientX;
          deltaX = 0;
          isDragging = true;
        }, { passive: true });

        track.addEventListener('touchmove', function (event) {
          if (!isDragging) return;
          deltaX = event.touches[0].clientX - startX;
        }, { passive: true });

        track.addEventListener('touchend', function () {
          if (!isDragging) return;
          if (Math.abs(deltaX) > 40) {
            if (deltaX < 0) {
              updateGallery(currentIndex + 1 > slides.length - 1 ? 0 : currentIndex + 1);
            } else {
              updateGallery(currentIndex - 1 < 0 ? slides.length - 1 : currentIndex - 1);
            }
          }
          isDragging = false;
          deltaX = 0;
        });
      }

      updateGallery(0);
    }

    var stickyBar = document.querySelector('.sticky-add-to-cart');
    var addToCartButton = document.querySelector('.primary-add-to-cart');
    var formSection = document.querySelector('.product-form');

    if (!stickyBar || !addToCartButton || !formSection) return;

    window.addEventListener('scroll', function () {
      var formBottom = formSection.getBoundingClientRect().bottom;

      if (formBottom < 130) {
        stickyBar.classList.add('open');
        stickyBar.setAttribute('aria-hidden', 'false');
      } else {
        stickyBar.classList.remove('open');
        stickyBar.setAttribute('aria-hidden', 'true');
      }
    });

    stickyBar.querySelector('.sticky-add-to-cart__button').addEventListener('click', function () {
      addToCartButton.click();
      stickyBar.classList.remove('open');
      stickyBar.setAttribute('aria-hidden', 'true');
    });
  });
</script>

{% schema %}
{
  "name": "t:general.product",
  "settings": [],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
