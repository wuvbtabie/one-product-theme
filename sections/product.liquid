{% comment %}
  This section is used in the product template to render product page with
  media, content, and add-to-cart form.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/product
{% endcomment %}

<div class="product-images">
  {% for image in product.images %}
    {% render 'image', class: 'product-image', image: image %}
  {% endfor %}
</div>

<div class="product-info">
  <div class="product-info__head">
    <h1>{{ product.title }}</h1>
    {% render 'wishlist-button',
      product: product,
      class: 'wishlist-inline-button'
    %}
  </div>
  <p>{{ product.price | money }}</p>
  <p>{{ product.description }}</p>
</div>

<div class="product-form">
  {% form 'product', product %}
    {% assign current_variant = product.selected_or_first_available_variant %}

    <select name="id">
      {% for variant in product.variants %}
        <option
          value="{{ variant.id }}"
          {% if variant == current_variant %}
            selected="selected"
          {% endif %}
        >
          {{ variant.title }} - {{ variant.price | money }}
        </option>
      {% endfor %}
    </select>

    <input type="number" name="quantity" min="1" value="1" aria-label="Quantity">

    <input type="submit" value="Add to cart" class="primary-add-to-cart">
    {{ form | payment_button }}
  {% endform %}

  <div class="sticky-add-to-cart" aria-hidden="true">
    <div class="sticky-add-to-cart__inner">
      <span class="sticky-add-to-cart__price">{{ current_variant.price | money }}</span>
      <button type="button" class="sticky-add-to-cart__button">Add to cart</button>
    </div>
  </div>
</div>

<style>
  .product-info__head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
  }

  .product-info__head h1 {
    margin: 0;
  }

  .product-info .wishlist-inline-button {
    margin-top: 2px;
  }

  .sticky-add-to-cart {
    position: fixed;
    left: 0;
    right: 0;
    bottom: -80px;
    background: #000;
    color: #fff;
    padding: 12px 16px;
    box-shadow: 0 -4px 16px rgba(0,0,0,0.2);
    transition: transform 0.25s ease, opacity 0.25s ease;
    transform: translateY(100%);
    opacity: 0;
    z-index: 220;
  }

  .sticky-add-to-cart.open {
    transform: translateY(0);
    opacity: 1;
  }

  .sticky-add-to-cart__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
  }

  .sticky-add-to-cart__price {
    font-weight: 700;
    font-size: 1rem;
  }

  .sticky-add-to-cart__button {
    background: #fff;
    color: #000;
    padding: 10px 16px;
    border: none;
    border-radius: 8px;
    font-weight: 700;
    cursor: pointer;
  }

  @media (min-width: 769px) {
    .sticky-add-to-cart { display: none; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var stickyBar = document.querySelector('.sticky-add-to-cart');
    var addToCartButton = document.querySelector('.primary-add-to-cart');
    var formSection = document.querySelector('.product-form');

    if (!stickyBar || !addToCartButton || !formSection) return;

    window.addEventListener('scroll', function () {
      var formBottom = formSection.getBoundingClientRect().bottom;

      if (formBottom < 130) {
        stickyBar.classList.add('open');
        stickyBar.setAttribute('aria-hidden', 'false');
      } else {
        stickyBar.classList.remove('open');
        stickyBar.setAttribute('aria-hidden', 'true');
      }
    });

    stickyBar.querySelector('.sticky-add-to-cart__button').addEventListener('click', function () {
      addToCartButton.click();
      stickyBar.classList.remove('open');
      stickyBar.setAttribute('aria-hidden', 'true');
    });
  });
</script>

{% schema %}
{
  "name": "t:general.product",
  "settings": [],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
