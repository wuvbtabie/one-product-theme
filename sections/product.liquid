{% comment %}
  This section is used in the product template to render product page with
  media, content, and add-to-cart form.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/product
{% endcomment %}

<div class="product-images">
  {% for image in product.images %}
    {% render 'image', class: 'product-image', image: image %}
  {% endfor %}
</div>

<div class="product-info">
  <div class="product-info__head">
    <h1>{{ product.title }}</h1>
    {% render 'wishlist-button',
      product: product,
      class: 'wishlist-inline-button'
    %}
  </div>
  <p>${{ product.price | money_without_currency }}</p>
  <p>{{ product.description }}</p>
</div>

<div class="product-form">
  {% form 'product', product %}
    {% assign current_variant = product.selected_or_first_available_variant %}

    {% if product.variants.size > 1 %}
      <div class="product-form__field product-form__field--variant">
        <label class="product-form__label" for="product-variant-select">Options</label>
        <div class="product-form__select-wrap">
          <select id="product-variant-select" name="id" class="product-form__select">
            {% for variant in product.variants %}
              <option
                value="{{ variant.id }}"
                {% if variant == current_variant %}
                  selected="selected"
                {% endif %}
              >
                {{ variant.title }} - ${{ variant.price | money_without_currency }}
              </option>
            {% endfor %}
          </select>
        </div>
      </div>
    {% else %}
      <input type="hidden" name="id" value="{{ current_variant.id }}">
    {% endif %}

    <div class="product-form__purchase-group">
      <div class="product-form__field product-form__field--quantity">
        <label class="product-form__label" for="product-quantity">Quantity</label>
        <input id="product-quantity" class="product-form__quantity" type="number" name="quantity" min="1" value="1" aria-label="Quantity">
      </div>

      <input type="submit" value="Add to cart" class="primary-add-to-cart">
    </div>

    <div class="product-form__payment-wrap">
      {{ form | payment_button }}
    </div>
  {% endform %}

  <div class="sticky-add-to-cart" aria-hidden="true">
    <div class="sticky-add-to-cart__inner">
      <span class="sticky-add-to-cart__price">${{ current_variant.price | money_without_currency }}</span>
      <button type="button" class="sticky-add-to-cart__button">Add to cart</button>
    </div>
  </div>
</div>

<style>
  .product-form form {
    display: grid;
    gap: 16px;
    margin-top: 22px;
  }

  .product-form__field {
    display: grid;
    gap: 8px;
  }

  .product-form__label {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #6c665f;
  }

  .product-form__select-wrap {
    position: relative;
  }

  .product-form__select-wrap::after {
    content: "";
    position: absolute;
    top: 50%;
    right: 18px;
    width: 10px;
    height: 10px;
    border-right: 1.5px solid #111;
    border-bottom: 1.5px solid #111;
    transform: translateY(-65%) rotate(45deg);
    pointer-events: none;
  }

  .product-form__select,
  .product-form__quantity {
    width: 100%;
    min-height: 52px;
    border: 1px solid #ddd6cb;
    border-radius: 16px;
    background: #fbfaf7;
    color: #111;
    font: inherit;
    padding: 0 18px;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.8);
  }

  .product-form__select {
    appearance: none;
    padding-right: 48px;
  }

  .product-form__quantity {
    max-width: 112px;
    text-align: center;
    font-weight: 700;
  }

  .product-form__purchase-group {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 14px;
    align-items: end;
  }

  .primary-add-to-cart {
    width: 100%;
    min-height: 54px;
    border: none;
    border-radius: 16px;
    background: #111;
    color: #fff;
    font: inherit;
    font-weight: 700;
    letter-spacing: 0.01em;
    cursor: pointer;
    transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
  }

  .primary-add-to-cart:hover {
    background: #1d1d1d;
    transform: translateY(-1px);
    box-shadow: 0 12px 24px rgba(17, 17, 17, 0.14);
  }

  .product-form__payment-wrap {
    display: grid;
    gap: 8px;
  }

  .product-form .shopify-payment-button {
    margin-top: 2px;
  }

  .product-form .shopify-payment-button__button {
    min-height: 46px !important;
    border-radius: 14px !important;
    overflow: hidden;
  }

  .product-form .shopify-payment-button__more-options {
    margin-top: 8px !important;
    font-size: 0.88rem !important;
    color: #5f5a56 !important;
  }

  .product-info__head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
  }

  .product-info__head h1 {
    margin: 0;
  }

  .product-info .wishlist-inline-button {
    margin-top: 2px;
  }

  .sticky-add-to-cart {
    position: fixed;
    left: 0;
    right: 0;
    bottom: -80px;
    background: #000;
    color: #fff;
    padding: 12px 16px;
    box-shadow: 0 -4px 16px rgba(0,0,0,0.2);
    transition: transform 0.25s ease, opacity 0.25s ease;
    transform: translateY(100%);
    opacity: 0;
    z-index: 220;
  }

  .sticky-add-to-cart.open {
    transform: translateY(0);
    opacity: 1;
  }

  .sticky-add-to-cart__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
  }

  .sticky-add-to-cart__price {
    font-weight: 700;
    font-size: 1rem;
  }

  .sticky-add-to-cart__button {
    background: #fff;
    color: #000;
    padding: 10px 16px;
    border: none;
    border-radius: 8px;
    font-weight: 700;
    cursor: pointer;
  }

  @media (min-width: 769px) {
    .sticky-add-to-cart { display: none; }
  }

  @media (max-width: 640px) {
    .product-form form {
      gap: 14px;
    }

    .product-form__purchase-group {
      grid-template-columns: 96px minmax(0, 1fr);
      gap: 10px;
    }

    .product-form__select,
    .product-form__quantity,
    .primary-add-to-cart {
      min-height: 50px;
      border-radius: 14px;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var stickyBar = document.querySelector('.sticky-add-to-cart');
    var addToCartButton = document.querySelector('.primary-add-to-cart');
    var formSection = document.querySelector('.product-form');

    if (!stickyBar || !addToCartButton || !formSection) return;

    window.addEventListener('scroll', function () {
      var formBottom = formSection.getBoundingClientRect().bottom;

      if (formBottom < 130) {
        stickyBar.classList.add('open');
        stickyBar.setAttribute('aria-hidden', 'false');
      } else {
        stickyBar.classList.remove('open');
        stickyBar.setAttribute('aria-hidden', 'true');
      }
    });

    stickyBar.querySelector('.sticky-add-to-cart__button').addEventListener('click', function () {
      addToCartButton.click();
      stickyBar.classList.remove('open');
      stickyBar.setAttribute('aria-hidden', 'true');
    });
  });
</script>

{% schema %}
{
  "name": "t:general.product",
  "settings": [],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
