<!-- Product Benefits Section -->
<section id="benefits" class="product-benefits">
  <div class="product-benefits__container">
    {% if section.settings.heading %}
      <h2 class="product-benefits__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="product-benefits__grid">
      {% if section.blocks.size > 0 %}
        {% for block in section.blocks %}
          <div class="product-benefits__item">
            {% if block.settings.icon %}
              <div class="product-benefits__icon">
                <img src="{{ block.settings.icon | img_url: '50x50' }}" alt="{{ block.settings.title }}" />
              </div>
            {% endif %}
            <h3 class="product-benefits__title">{{ block.settings.title }}</h3>
            <p class="product-benefits__description">{{ block.settings.description }}</p>
          </div>
        {% endfor %}
      {% else %}
        <div class="product-benefits__item">
          <h3 class="product-benefits__title">High Quality</h3>
          <p class="product-benefits__description">Premium materials and expert craftsmanship in every product.</p>
        </div>
        <div class="product-benefits__item">
          <h3 class="product-benefits__title">Fast Delivery</h3>
          <p class="product-benefits__description">Quick, reliable shipping straight to your doorstep.</p>
        </div>
        <div class="product-benefits__item">
          <h3 class="product-benefits__title">Great Support</h3>
          <p class="product-benefits__description">24/7 customer service ready to help you anytime.</p>
        </div>
      {% endif %}
    </div>
  </div>
</section>

<style>
  .product-benefits {
    background-color: #ffffff;
    padding: 70px 20px;
  }

  .product-benefits__container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .product-benefits__heading {
    text-align: center;
    font-size: 42px;
    font-weight: 700;
    margin: 0 0 45px 0;
    color: #1a1a1a;
    letter-spacing: -0.8px;
    line-height: 1.2;
  }

  .product-benefits__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }

  .product-benefits__item {
    background: white;
    border-radius: 20px;
    padding: 40px 24px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }

  .product-benefits__item:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
    transform: translateY(-2px);
  }

  .product-benefits__icon {
    margin-bottom: 24px;
    display: flex;
    justify-content: center;
    align-items: center;
    width: 64px;
    height: 64px;
  }

  .product-benefits__icon img {
    max-width: 50px;
    height: auto;
  }

  .product-benefits__title {
    font-size: 18px;
    font-weight: 600;
    color: #1a1a1a;
    margin: 0 0 16px 0;
    line-height: 1.3;
  }

  .product-benefits__description {
    font-size: 15px;
    color: #666;
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 768px) {
    .product-benefits {
      padding: 40px 16px;
    }

    .product-benefits__heading {
      font-size: 32px;
      margin-bottom: 35px;
      letter-spacing: -0.5px;
    }

    .product-benefits__grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .product-benefits__item {
      padding: 32px 20px;
    }

    .product-benefits__icon {
      margin-bottom: 20px;
    }

    .product-benefits__title {
      font-size: 16px;
      margin-bottom: 12px;
    }

    .product-benefits__description {
      font-size: 14px;
    }
  }
</style>

{% schema %}
{
  "name": "Product Benefits",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why Choose Our Product"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Benefit Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Add your benefit description here"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Benefits",
      "settings": {
        "heading": "Why Choose Our Product"
      },
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "title": "High Quality",
            "description": "Premium materials and expert craftsmanship"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "title": "Fast Delivery",
            "description": "Quick shipping to your doorstep"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "title": "Great Support",
            "description": "24/7 customer service available"
          }
        }
      ]
    }
  ]
}
{% endschema %}
