{% if section.settings.show_announcement and section.settings.text != blank %}
  <div class="announcement-bar" role="region" aria-label="Announcement">
    <div
      class="announcement-bar__inner"
      style="background-color: {{ section.settings.background_color }}; color: {{ section.settings.text_color }};"
    >
      <div class="announcement-bar__marquee" aria-live="off">
        <div class="announcement-bar__track">
          <span class="announcement-bar__segment">{{ section.settings.text }}</span>
          <span class="announcement-bar__sep" aria-hidden="true">&nbsp;&nbsp;•&nbsp;&nbsp;</span>
          <span class="announcement-bar__segment" aria-hidden="true">Secure Checkout</span>
          <span class="announcement-bar__sep" aria-hidden="true">&nbsp;&nbsp;•&nbsp;&nbsp;</span>
          <span class="announcement-bar__segment" aria-hidden="true">30-Day Money-Back Guarantee</span>
          <span class="announcement-bar__sep" aria-hidden="true">&nbsp;&nbsp;•&nbsp;&nbsp;</span>
          <span class="announcement-bar__segment" aria-hidden="true">1-Year Warranty</span>
          <span class="announcement-bar__sep" aria-hidden="true">&nbsp;&nbsp;•&nbsp;&nbsp;</span>
          <!-- duplicate for seamless loop -->
          <span class="announcement-bar__segment" aria-hidden="true">{{ section.settings.text }}</span>
          <span class="announcement-bar__sep" aria-hidden="true">&nbsp;&nbsp;•&nbsp;&nbsp;</span>
          <span class="announcement-bar__segment" aria-hidden="true">Secure Checkout</span>
          <span class="announcement-bar__sep" aria-hidden="true">&nbsp;&nbsp;•&nbsp;&nbsp;</span>
          <span class="announcement-bar__segment" aria-hidden="true">30-Day Money-Back Guarantee</span>
          <span class="announcement-bar__sep" aria-hidden="true">&nbsp;&nbsp;•&nbsp;&nbsp;</span>
          <span class="announcement-bar__segment" aria-hidden="true">1-Year Warranty</span>
          <span class="announcement-bar__sep" aria-hidden="true">&nbsp;&nbsp;•&nbsp;&nbsp;</span>
        </div>
      </div>
    </div>
  </div>
{% endif %}

<style>
  .announcement-bar {
    width: 100%;
  }

  .announcement-bar__inner {
    display: block;
    min-height: 32px;
    padding: 6px 0;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.4px;
    line-height: 1.4;
    overflow: hidden;
    text-decoration: none;
  }

  .announcement-bar__marquee {
    overflow: hidden;
    width: 100%;
  }

  .announcement-bar__track {
    display: inline-flex;
    white-space: nowrap;
    animation: announcement-scroll 28s linear infinite;
  }

  .announcement-bar__segment,
  .announcement-bar__sep {
    flex-shrink: 0;
  }

  @keyframes announcement-scroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .announcement-bar__track {
      animation: none;
      justify-content: center;
      width: 100%;
    }
  }

  @media (max-width: 640px) {
    .announcement-bar__inner {
      min-height: 28px;
      padding: 5px 0;
      font-size: 11px;
    }
  }
</style>

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show announcement bar",
      "default": true
    },
    {
      "type": "text",
      "id": "text",
      "label": "Announcement text",
      "default": "🚚 Free shipping on orders over $99"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link (optional)"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar",
      "settings": {
        "show_announcement": true,
        "text": "🚚 Free shipping on orders over $99",
        "background_color": "#000000",
        "text_color": "#ffffff"
      }
    }
  ]
}
{% endschema %}
