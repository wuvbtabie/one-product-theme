{% if section.settings.show_announcement and section.settings.text != blank %}
  <div class="announcement-bar" role="region" aria-label="Announcement">
    <div
      class="announcement-bar__inner"
      style="background-color: {{ section.settings.background_color }}; color: {{ section.settings.text_color }};"
    >
      <p class="announcement-bar__text">{{ section.settings.text }}</p>
    </div>
  </div>
{% endif %}

<style>
  .announcement-bar {
    width: 100%;
  }

  .announcement-bar__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 36px;
    padding: 7px 16px;
    text-align: center;
  }

  .announcement-bar__text {
    margin: 0;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.3px;
    line-height: 1.4;
  }

  @media (max-width: 640px) {
    .announcement-bar__inner {
      min-height: 30px;
      padding: 6px 12px;
    }
    .announcement-bar__text {
      font-size: 11px;
    }
  }
</style>

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show announcement bar",
      "default": true
    },
    {
      "type": "text",
      "id": "text",
      "label": "Announcement text",
      "default": "🚚 Free shipping on orders over $99"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link (optional)"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar",
      "settings": {
        "show_announcement": true,
        "text": "🚚 Free shipping on orders over $99",
        "background_color": "#000000",
        "text_color": "#ffffff"
      }
    }
  ]
}
{% endschema %}
