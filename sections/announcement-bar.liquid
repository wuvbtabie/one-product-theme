{% if section.settings.show_announcement and section.settings.text != blank %}
  <div class="announcement-bar" role="region" aria-label="Announcement">
    <div
      class="announcement-bar__inner"
      style="background-color: {{ section.settings.background_color }}; color: {{ section.settings.text_color }};"
    >
      <p class="announcement-bar__text" data-announcement-typing>{{ section.settings.text }}</p>
    </div>
  </div>
{% endif %}

<style>
  .announcement-bar {
    width: 100%;
    overflow: hidden;
  }

  .announcement-bar__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100vw;
    margin-left: calc(-50vw + 50%);
    min-height: 36px;
    padding: 7px 16px;
    text-align: center;
  }

  .announcement-bar__text {
    margin: 0;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.3px;
    line-height: 1.4;
  }

  .announcement-bar__text.is-typing::after {
    content: "";
    display: inline-block;
    width: 2px;
    height: 0.9em;
    margin-left: 5px;
    background: currentColor;
    vertical-align: -0.08em;
    animation: announcement-caret 0.9s steps(1, end) infinite;
  }

  @keyframes announcement-caret {
    0%, 49% {
      opacity: 1;
    }

    50%, 100% {
      opacity: 0;
    }
  }

  @media (max-width: 640px) {
    .announcement-bar__inner {
      min-height: 30px;
      padding: 6px 12px;
    }
    .announcement-bar__text {
      font-size: 11px;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var announcementText = document.querySelector('[data-announcement-typing]');
    if (!announcementText) return;
    if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    var fullText = (announcementText.textContent || '').trim();
    if (!fullText) return;

    function runTypingLoop() {
      var index = 0;

      announcementText.textContent = '';
      announcementText.classList.add('is-typing');

      var timer = window.setInterval(function () {
        index += 1;
        announcementText.textContent = fullText.slice(0, index);

        if (index >= fullText.length) {
          window.clearInterval(timer);
          announcementText.classList.remove('is-typing');
          window.setTimeout(runTypingLoop, 1800);
        }
      }, 28);
    }

    runTypingLoop();
  });
</script>

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show announcement bar",
      "default": true
    },
    {
      "type": "text",
      "id": "text",
      "label": "Announcement text",
      "default": "🚚 Free shipping on orders over $99"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link (optional)"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar",
      "settings": {
        "show_announcement": true,
        "text": "🚚 Free shipping on orders over $99",
        "background_color": "#000000",
        "text_color": "#ffffff"
      }
    }
  ]
}
{% endschema %}
