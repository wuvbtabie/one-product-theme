{% comment %}
  This section is used in the cart template to render /cart page with an
  overview of the items in customer's cart.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/cart
{% endcomment %}

<section class="cart-page">
  <h1 class="cart-page__title">{{ 'cart.title' | t }}</h1>

  {% if cart.item_count > 0 %}
    <form action="{{ routes.cart_url }}" method="post" class="cart-page__form">
      <div class="cart-page__items">
        {% for item in cart.items %}
          <article class="cart-item">
            <div class="cart-item__image">
              {% render 'image', image: item.image, url: item.url, class: 'cart-item__image-wrap', width: 250 %}
            </div>

            <div class="cart-item__content">
              <a class="cart-item__title" href="{{ item.url }}">{{ item.product.title }}</a>

              <p class="cart-item__price-row">
                <span class="cart-item__price">{{ item.final_price | money }}</span>
                {% if item.variant.compare_at_price > item.final_price %}
                  <s class="cart-item__compare">{{ item.variant.compare_at_price | money }}</s>
                {% endif %}
              </p>

              <div class="cart-item__controls">
                <label class="cart-item__qty-label" for="cart-qty-{{ forloop.index }}">Qty</label>
                <input id="cart-qty-{{ forloop.index }}" class="cart-item__qty" type="number" name="updates[]" min="0" value="{{ item.quantity }}">
                <a class="cart-item__remove" href="{{ item.url_to_remove }}">{{ 'cart.remove' | t }}</a>
              </div>
            </div>
          </article>
        {% endfor %}
      </div>

      <div class="cart-page__footer">
        <p class="cart-page__subtotal">Subtotal: <strong>{{ cart.total_price | money }}</strong></p>
        <div class="cart-page__actions">
          <button type="submit" class="cart-page__update">{{ 'cart.update' | t }}</button>
          <button type="submit" name="checkout" class="cart-page__checkout">{{ 'cart.checkout' | t }}</button>
        </div>
      </div>
    </form>
  {% else %}
    <p class="cart-page__empty">Your cart is empty.</p>
  {% endif %}
</section>

<style>
  .cart-page {
    max-width: 1100px;
    margin: 0 auto;
    padding: 30px 16px 56px;
  }

  .cart-page__title {
    margin: 0 0 20px;
    font-size: clamp(1.6rem, 2.8vw, 2.2rem);
    letter-spacing: -0.02em;
  }

  .cart-page__items {
    display: grid;
    gap: 14px;
  }

  .cart-item {
    display: grid;
    grid-template-columns: minmax(0, 250px) minmax(0, 1fr);
    gap: 20px;
    align-items: center;
    border: 1px solid #e8e8e8;
    border-radius: 10px;
    background: #fff;
    padding: 14px;
  }

  .cart-item__image-wrap {
    max-width: 250px;
  }

  .cart-item__image-wrap img,
  .cart-item__image img {
    max-width: 250px;
    width: 100%;
    height: auto;
    object-fit: contain;
    display: block;
  }

  .cart-item__content {
    min-width: 0;
  }

  .cart-item__title {
    display: inline-block;
    color: #141414;
    font-size: 1.05rem;
    font-weight: 700;
    text-decoration: none;
    margin: 0 0 8px;
  }

  .cart-item__price-row {
    margin: 0 0 12px;
    display: flex;
    align-items: baseline;
    gap: 10px;
  }

  .cart-item__price {
    font-size: 1.25rem;
    font-weight: 700;
    color: #111;
  }

  .cart-item__compare {
    color: #7b7b7b;
    font-size: 0.95rem;
  }

  .cart-item__controls {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .cart-item__qty-label {
    font-size: 0.86rem;
    color: #666;
  }

  .cart-item__qty {
    width: 80px;
    height: 38px;
    border: 1px solid #d9d9d9;
    border-radius: 6px;
    padding: 0 10px;
  }

  .cart-item__remove {
    color: #111;
    font-size: 0.86rem;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .cart-page__footer {
    margin-top: 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    flex-wrap: wrap;
  }

  .cart-page__subtotal {
    margin: 0;
    font-size: 1rem;
  }

  .cart-page__actions {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .cart-page__update,
  .cart-page__checkout {
    height: 44px;
    border-radius: 999px;
    border: 1px solid #111;
    padding: 0 20px;
    font-weight: 700;
    cursor: pointer;
  }

  .cart-page__update {
    background: #fff;
    color: #111;
  }

  .cart-page__checkout {
    background: #111;
    color: #fff;
  }

  .cart-page__empty {
    color: #555;
    font-size: 1rem;
  }

  @media (max-width: 720px) {
    .cart-item {
      grid-template-columns: 1fr;
    }

    .cart-item__image-wrap,
    .cart-item__image-wrap img,
    .cart-item__image img {
      max-width: 100%;
    }
  }
</style>

{% schema %}
{
  "name": "t:general.cart",
  "settings": []
}
{% endschema %}
