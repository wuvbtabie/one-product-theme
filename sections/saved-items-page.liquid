{% comment %}
  Dedicated page section for saved items.
{% endcomment %}

<section class="saved-items-view">
  <div class="saved-items-view__hero">
    <p class="saved-items-view__eyebrow">Saved for later</p>
    <h1 class="saved-items-view__title">{{ page.title | default: 'Saved Items' }}</h1>
    <p class="saved-items-view__subtitle">Everything you have parked for later, presented in a cleaner full-page layout that feels closer to a modern wishlist.</p>
  </div>

  <div class="saved-items-view__panel saved-items-page" data-wishlist-page-section tabindex="-1">
    <div class="saved-items-page__header">
      <div>
        <p class="saved-items-view__eyebrow saved-items-view__eyebrow--section">Wishlist</p>
        <h2 class="saved-items-page__title">Saved pieces</h2>
      </div>
      <span class="saved-items-page__count" data-wishlist-page-count>0</span>
    </div>

    <p class="saved-items-page__empty" data-wishlist-page-empty>Nothing saved yet. Items moved out of your bag will appear here.</p>
    <div class="saved-items-page__items" data-wishlist-page-items></div>
  </div>
</section>

<style>
  .saved-items-view {
    max-width: 1380px;
    margin: 0 auto;
    padding: 22px 24px 52px;
    color: #111;
  }

  .saved-items-view__hero {
    margin-bottom: 18px;
  }

  .saved-items-view__eyebrow {
    margin: 0 0 10px;
    color: #76706a;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .saved-items-view__eyebrow--section {
    margin-bottom: 8px;
  }

  .saved-items-view__title {
    margin: 0;
    font-size: clamp(1.7rem, 3vw, 2.6rem);
    line-height: 1.02;
    letter-spacing: -0.04em;
    text-wrap: balance;
  }

  .saved-items-view__subtitle {
    max-width: 760px;
    margin: 10px 0 0;
    color: #5f5a56;
    font-size: 0.96rem;
    line-height: 1.55;
  }

  .saved-items-view__panel {
    border: 1px solid #e6dfd4;
    border-radius: 30px;
    background: linear-gradient(180deg, #fdfbf7 0%, #f7f2ea 100%);
    box-shadow: 0 18px 48px rgba(17, 17, 17, 0.06);
    padding: 22px 24px;
  }

  .saved-items-page__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 20px;
  }

  .saved-items-page__title {
    margin: 0;
    font-size: clamp(1.15rem, 2vw, 1.5rem);
    line-height: 1.12;
    letter-spacing: -0.03em;
  }

  .saved-items-page__count {
    min-width: 44px;
    height: 44px;
    padding: 0 14px;
    border-radius: 999px;
    border: 1px solid #ddd4c6;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.88rem;
    font-weight: 700;
    color: #3a3531;
    background: rgba(255, 255, 255, 0.9);
  }

  .saved-items-page__empty {
    margin: 0;
    color: #68625d;
    font-size: 0.98rem;
    line-height: 1.6;
  }

  .saved-items-page__empty--hidden {
    display: none;
  }

  .saved-items-page__items {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
    margin-top: 16px;
  }

  @media (max-width: 980px) {
    .saved-items-page__items {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .saved-items-view {
      padding: 18px 14px 42px;
    }

    .saved-items-view__panel {
      border-radius: 24px;
      padding: 18px;
    }
  }
</style>

{% schema %}
{
  "name": "Saved Items Page",
  "settings": []
}
{% endschema %}
